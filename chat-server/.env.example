# Environment Configuration
NODE_ENV=development
PORT=3001
HOST=localhost
LOG_LEVEL=info
LOG_FORMAT=json

# SSL Configuration (for development only)
NODE_TLS_REJECT_UNAUTHORIZED=0

# Eliza API Configuration
ELIZA_KEY=your_eliza_api_key_here
ELIZA_BASE_URL=https://api.eliza.yandex.net/raw/openai/v1
MODEL_NAME=gpt-4.1

# MCP Server Configuration
MCP_SERVER_URL=http://ui-dev-0.ydb.yandex.net:8784/meta/mcp

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Security
API_KEY_HEADER=x-api-key
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Health Check
HEALTH_CHECK_INTERVAL_MS=30000
MCP_CONNECTION_TIMEOUT_MS=5000
MCP_TOOL_CALL_TIMEOUT_MS=30000
MCP_TOOL_CALL_CONCURRENCY=10
